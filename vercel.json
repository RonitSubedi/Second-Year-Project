{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "regions": ["sin1"],
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "headers": [
    {
      "source": "/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Credentials",
          "value": "true"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET,OPTIONS,PATCH,DELETE,POST,PUT"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization, X-Requested-With"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/auth/:path*",
      "destination": "/_/backend/auth/:path*"
    },
    {
      "source": "/api/payment/:path*",
      "destination": "/_/backend/payment/:path*"
    },
    {
      "source": "/api/registration/:path*",
      "destination": "/_/backend/registration/:path*"
    },
    {
      "source": "/api/feedback/:path*",
      "destination": "/_/backend/feedback/:path*"
    },
    {
      "source": "/api/user/:path*",
      "destination": "/_/backend/user/:path*"
    },
    {
      "source": "/api/bus-location/:path*",
      "destination": "/_/backend/bus-location/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "/_/backend/socket.io/:path*"
    }
  ]
}
